   "source": [
    "## Step 2 - Create Project Configuration\n",
    "\n",
    "Let's create a configuration file that defines our project parameters including datasets, model architecture, and training parameters."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Create the configs directory if it doesn't exist\n",
    "os.makedirs(\"configs\", exist_ok=True)\n",
    "\n",
    "# Define the project configuration\n",
    "config = {\n",
    "    \"project_name\": f\"advanced-ai-model-{datetime.now().strftime('%Y%m%d')}\",\n",
    "    \"seed\": 42,\n",
    "    \"output_dir\": \"outputs\",\n",
    "    \n",
    "    \"datasets\": {\n",
    "        \"core_datasets\": [\n",
    "            # We'll select a subset of datasets from README for demonstration purposes\n",
    "            {\"name\": \"HuggingFaceH4/instruction-dataset\", \"type\": \"huggingface\", \"task\": \"instruction_following\", \"streaming\": False, \"max_samples\": 5000},\n",
    "            {\"name\": \"HuggingFaceH4/ultrachat_200k\", \"type\": \"huggingface\", \"task\": \"dialogue\", \"streaming\": False, \"max_samples\": 5000},\n",
    "            {\"name\": \"tatsu-lab/alpaca\", \"type\": \"huggingface\", \"task\": \"instruction_following\", \"streaming\": False, \"max_samples\": 5000},\n",
    "            {\"name\": \"databricks/databricks-dolly-15k\", \"type\": \"huggingface\", \"task\": \"instruction_following\", \"streaming\": False},\n",
    "        ],\n",
    "        \"additional_datasets\": [\n",
    "            # Additional datasets if needed\n",
    "        ]\n",
    "    },\n",
    "    \n",
    "    \"tokenizer\": {\n",
    "        \"type\": \"huggingface\",\n",
    "        \"name\": \"mistralai/Mistral-7B-v0.1\",  # We'll use Mistral's tokenizer\n",
    "        \"vocab_size\": 32000,\n",
    "        \"model_max_length\": 4096\n",
    "    },\n",
    "    \n",
    "    \"model\": {\n",
    "        \"size\": \"small\",  # For demonstration purposes\n",
    "        \"sizes\": {\n",
    "            \"small\": {\n",
    "                \"n_layers\": 12,\n",
    "                \"n_heads\": 12,\n",
    "                \"d_model\": 768,\n",
    "                \"d_ff\": 3072,\n",
    "                \"max_seq_length\": 2048\n",
    "            },\n",
    "            \"medium\": {\n",
    "                \"n_layers\": 24,\n",
    "                \"n_heads\": 16,\n",
    "                \"d_model\": 1024,\n",
    "                \"d_ff\": 4096,\n",
    "                \"max_seq_length\": 4096\n",
    "            },\n",
    "            \"large\": {\n",
    "                \"n_layers\": 32,\n",
    "                \"n_heads\": 32,\n",
    "                \"d_model\": 2048,\n",
    "                \"d_ff\": 8192,\n",
    "                \"max_seq_length\": 8192\n",
    "            }\n",
    "        },\n",
    "        \"dropout\": 0.1,\n",
    "        \"attention\": {\n",
    "            \"causal\": True,\n",
    "            \"rotary_embedding\": True\n",
    "        },\n",
    "        \"base_model\": \"mistralai/Mistral-7B-v0.1\"  # For fine-tuning rather than training from scratch\n",
    "    },\n",
    "    \n",
    "    \"training\": {\n",
    "        \"stages\": [\n",
    "            {\n",
    "                \"name\": \"instruction_tuning\",\n",
    "                \"datasets\": [\"HuggingFaceH4/instruction-dataset\", \"tatsu-lab/alpaca\", \"databricks/databricks-dolly-15k\"],\n",
    "                \"epochs\": 3,\n",
    "                \"learning_rate\": {\n",
    "                    \"initial\": 2e-5,\n",
    "                    \"min\": 1e-6,\n",
    "                    \"schedule\": \"cosine\",\n",
    "                    \"warmup_steps\": 100\n",
    "                }\n",
    "            },\n",
    "            {\n",
    "                \"name\": \"dialogue_tuning\",\n",
    "                \"datasets\": [\"HuggingFaceH4/ultrachat_200k\"],\n",
    "                \"epochs\": 2,\n",
    "                \"learning_rate\": {\n",
    "                    \"initial\": 1e-5,\n",
    "                    \"min\": 5e-7,\n",
    "                    \"schedule\": \"cosine\",\n",
    "                    \"warmup_steps\": 50\n",
    "                }\n",
    "            }\n",
    "        ],\n",
    "        \"optimizer\": {\n",
    "            \"name\": \"adamw\",\n",
    "            \"weight_decay\": 0.01,\n",
    "            \"beta1\": 0.9,\n",
    "            \"beta2\": 0.999,\n",
    "            \"eps\": 1e-8,\n",
    "            \"use_8bit\": True\n",
    "        },\n",
    "        \"mixed_precision\": \"fp16\",\n",
    "        \"gradient_checkpointing\": True,\n",
    "        \"gradient_clipping\": 1.0,\n",
    "        \"checkpointing\": {\n",
    "            \"save_steps\": 500,\n",
    "            \"keep_last_n\": 3,\n",
    "            \"save_optimizer_state\": True\n",
    "        },\n",
    "        \"evaluation\": {\n",
    "            \"eval_steps\": 500,\n",
    "            \"early_stopping\": {\n",
    "                \"enabled\": True,\n",
    "                \"patience\": 3,\n",
    "                \"metric\": \"eval_loss\",\n",
    "                \"mode\": \"min\"\n",
    "            }\n",
    "        },\n",
    "        \"use_peft\": True,  # Parameter-Efficient Fine-Tuning\n",
    "        \"peft_config\": {\n",
    "            \"r\": 16,\n",
    "            \"lora_alpha\": 32,\n",
    "            \"lora_dropout\": 0.05,\n",
    "            \"target_modules\": [\"q_proj\", \"v_proj\"],\n",
    "            \"bias\": \"none\"\n",
    "        }\n",
    "    },\n",
    "    \n",
    "    \"data_processing\": {\n",
    "        \"preprocessing\": {\n",
    "            \"normalize_unicode\": True,\n",
    "            \"normalize_whitespace\": True,\n",
    "            \"remove_html\": True,\n",
    "            \"min_length\": 10,\n",
    "            \"max_length\": 16384\n",
    "        },\n",
    "        \"augmentation\": {\n",
    "            \"enabled\": False\n",
    "        },\n",
    "        \"batching\": {\n",
    "            \"train_batch_size\": 4,\n",
    "            \"eval_batch_size\": 4,\n",
    "            \"gradient_accumulation_steps\": 8,\n",
    "            \"dynamic_batching\": True\n",
    "        }\n",
    "    },\n",
    "    \n",
    "    \"error_handling\": {\n",
    "        \"fallbacks\": {\n",
    "            \"dataset_unavailable\": \"use_cached\"\n",
    "        }\n",
    "    },\n",
    "    \n",
    "    \"flask\": {\n",
    "        \"batch_size\": 1,\n",
    "        \"max_concurrent_requests\": 5,\n",
    "        \"timeout\": 60,\n",
    "        \"cache_size\": 100,\n",
    "        \"async_mode\": True\n",
    "    },\n",
    "    \n",
    "    \"coreml\": {\n",
    "        \"quantization\": {\n",
    "            \"enabled\": True,\n",
    "            \"precision\": \"int8\"\n",
    "        },\n",
    "        \"pruning\": {\n",
    "            \"enabled\": False,\n",
    "            \"method\": \"magnitude\",\n",
    "            \"target_sparsity\": 0.3\n",
    "        },\n",
    "        \"optimization\": {\n",
    "            \"compute_precision\": \"float16\",\n",
    "            \"memory_layout\": \"gpu_family\"\n",
    "        }\n",
    "    }\n",
    "}\n",
    "\n",
    "# Save the configuration to a YAML file\n",
    "config_path = \"configs/config.yaml\"\n",
    "with open(config_path, 'w') as f:\n",
    "    yaml.dump(config, f, sort_keys=False)\n",
    "\n",
    "print(f\"Configuration saved to {config_path}\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Step 3 - Load and Preprocess Datasets\n",
    "\n",
    "Using the project configuration, we'll now load and preprocess the specified datasets."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Initialize the dataset loader with our configuration\n",
    "dataset_loader = DatasetLoader(config_path)\n",
    "\n",
    "# Initialize preprocessor\n",
    "data_preprocessor = DataPreprocessor(config)\n",
    "\n",
    "# Load all datasets specified in the config\n",
    "datasets = {}\n",
    "for stage in config['training']['stages']:\n",
    "    stage_name = stage['name']\n",
    "    stage_datasets = []\n",
    "    \n",
    "    print(f\"Loading datasets for {stage_name}...\")\n",
    "    for dataset_name in stage['datasets']:\n",
    "        try:\n",
    "            print(f\"  Loading {dataset_name}...\")\n",
    "            dataset = dataset_loader.load_dataset(dataset_name, split=\"train\")\n",
    "            print(f\"  Loaded {dataset_name} with {len(dataset)} examples\")\n",
    "            \n",
    "            # Preprocess the dataset\n",
    "            print(f\"  Preprocessing {dataset_name}...\")\n",
    "            preprocessed_dataset = data_preprocessor.process_dataset(dataset)\n",
    "            \n",
    "            # Get dataset task type from config\n",
    "            task_type = next((d['task'] for d in config['datasets']['core_datasets'] if d['name'] == dataset_name), \"general\")\n",
    "            \n",
    "            # Standardize the dataset format\n",
    "            unified_dataset = data_preprocessor.unify_dataset_format(preprocessed_dataset, task_type)\n",
    "            \n",
    "            # Add to stage datasets\n",
    "            stage_datasets.append(unified_dataset)\n",
    "            \n",
    "        except Exception as e:\n",
    "            print(f\"  Error loading {dataset_name}: {e}\")\n",
    "    \n",
    "    # Combine datasets for this stage\n",
    "    if stage_datasets:\n",
    "        datasets[stage_name] = concatenate_datasets(stage_datasets)\n",
    "        print(f\"Combined {len(datasets[stage_name])} examples for {stage_name}\")\n",
    "    else:\n",
    "        print(f\"No datasets loaded for {stage_name}\")\n",
    "\n",
    "# Count the total number of examples\n",
    "total_examples = sum(len(dataset) for dataset in datasets.values())\n",
    "print(f\"\\nTotal examples across all stages: {total_examples}\")"
   ]
