   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 2. Dataset Loading & Preprocessing\n",
    "\n",
    "Load and preprocess datasets for model training."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "print(\"\\n==== DATASET LOADING & PREPROCESSING ====\\n\")\n",
    "\n",
    "# Import dataset modules, with fallback to direct HuggingFace imports\n",
    "try:\n",
    "    from src.data.loaders import DatasetLoader\n",
    "    from src.data.preprocessors import DataPreprocessor\n",
    "    print(\"✅ Successfully imported project data modules\")\n",
    "    module_source = \"project\"\n",
    "except ImportError:\n",
    "    # Fall back to direct HuggingFace imports\n",
    "    print(\"ℹ️ Could not import from src directory, loading from datasets package directly\")\n",
    "    from datasets import load_dataset, concatenate_datasets\n",
    "    module_source = \"huggingface\"\n",
    "\n",
    "print(f\"Using {module_source} as the data source\")\n",
    "\n",
    "# Function to load and process datasets\n",
    "def load_and_process_datasets():\n",
    "    if module_source == \"project\":\n",
    "        print(\"Loading datasets using project's DatasetLoader...\")\n",
    "        # Initialize dataset loader with config and token\n",
    "        loader = DatasetLoader(config_output_path, huggingface_token=os.environ.get(\"HUGGINGFACE_TOKEN\"))\n",
    "        \n",
    "        # Get information about all configured datasets\n",
    "        datasets_info = loader.get_all_datasets_info()\n",
    "        print(f\"Found {len(datasets_info)} datasets in configuration\")\n",
    "        \n",
    "        # Initialize preprocessor\n",
    "        preprocessor = DataPreprocessor(config)\n",
    "        \n",
    "        # Determine which datasets to process based on training stages\n",
    "        if 'training' in config and 'stages' in config['training'] and len(config['training']['stages']) > 0:\n",
    "            first_stage = config['training']['stages'][0]['name']\n",
    "            stage_datasets = config['training']['stages'][0]['datasets']\n",
    "        else:\n",
    "            # Use core datasets if no stages defined\n",
    "            first_stage = \"default\"\n",
    "            stage_datasets = [d['name'] for d in config['datasets']['core_datasets']]\n",
    "        \n",
    "        print(f\"Processing datasets for {first_stage} stage: {stage_datasets}\")\n",
    "        processed_datasets = []\n",
    "        \n",
    "        # Try to process each dataset in the stage\n",
    "        for dataset_name in stage_datasets:\n",
    "            try:\n",
    "                # Get dataset configuration if available\n",
    "                try:\n",
    "                    dataset_config = loader._get_dataset_config(dataset_name)\n",
    "                    task_type = dataset_config.get('task', 'unknown')\n",
    "                    streaming = dataset_config.get('streaming', False)\n",
    "                    max_samples = dataset_config.get('max_samples', 100)  # Limit samples for Kaggle\n",
    "                except Exception as e:\n",
    "                    print(f\"Warning: Could not get dataset config for {dataset_name}: {e}\")\n",
    "                    task_type = \"unknown\"\n",
    "                    streaming = False\n",
    "                    max_samples = 100\n",
    "                \n",
    "                # Load dataset\n",
    "                print(f\"Loading dataset: {dataset_name}\")\n",
    "                dataset = loader.load_dataset(\n",
    "                    dataset_name, \n",
    "                    streaming=streaming,\n",
    "                    max_samples=max_samples\n",
    "                )\n",
    "                \n",
    "                # Process dataset\n",
    "                print(f\"Processing dataset: {dataset_name}\")\n",
    "                processed_dataset = preprocessor.process_dataset(dataset)\n",
    "                \n",
    "                # Unify dataset format\n",
    "                unified_dataset = preprocessor.unify_dataset_format(processed_dataset, task_type)\n",
    "                \n",
    "                # Create training pairs\n",
    "                training_pairs = preprocessor.create_training_pairs(unified_dataset)\n",
    "                \n",
    "                # Add to list\n",
    "                processed_datasets.append(training_pairs)\n",
    "                \n",
    "                print(f\"✅ Dataset {dataset_name} processed successfully\")\n",
    "                \n",
    "            except Exception as e:\n",
    "                print(f\"⚠️ Error processing dataset {dataset_name}: {e}. Skipping.\")\n",
    "        \n",
    "        # Combine datasets (if not streaming)\n",
    "        if not processed_datasets:\n",
    "            print(\"No datasets processed. Loading sample dataset.\")\n",
    "            from datasets import load_dataset\n",
    "            train_dataset = load_dataset(\"openai/humaneval\", split=\"train\")\n",
    "        elif not any(getattr(ds, '_is_streaming', False) for ds in processed_datasets):\n",
    "            train_dataset = concatenate_datasets(processed_datasets)\n",
    "            print(f\"Combined dataset size: {len(train_dataset)} examples\")\n",
    "        else:\n",
    "            # Use the first processed dataset if streaming\n",
    "            train_dataset = processed_datasets[0]\n",
    "            print(\"Using streaming dataset\")\n",
    "        \n",
    "        # Save dataset for later use (if not streaming)\n",
    "        dataset_path = f\"{output_dir}/datasets/{first_stage}_dataset\"\n",
    "        if not getattr(train_dataset, '_is_streaming', False):\n",
    "            train_dataset.save_to_disk(dataset_path)\n",
    "            print(f\"✅ Dataset saved to {dataset_path}\")\n",
    "    else:\n",
    "        # Direct HuggingFace loading for fallback\n",
    "        print(\"Loading datasets directly from HuggingFace...\")\n",
    "        \n",
    "        # Try to load a code generation dataset first\n",
    "        try:\n",
    "            train_dataset = load_dataset(\"openai/humaneval\", split=\"train\")\n",
    "        except Exception as e:\n",
    "            print(f\"Error loading humaneval: {e}\")\n",
    "            try:\n",
    "                # Fall back to a general dataset\n",
    "                train_dataset = load_dataset(\"imdb\", split=\"train\").select(range(1000))\n",
    "            except Exception as e2:\n",
    "                print(f\"Error loading fallback dataset: {e2}\")\n",
    "                # Create a tiny synthetic dataset as last resort\n",
    "                from datasets import Dataset\n",
    "                train_dataset = Dataset.from_dict({\n",
    "                    \"text\": [\"This is example \" + str(i) for i in range(100)]\n",
    "                })\n",
    "        \n",
    "        print(f\"✅ Loaded dataset with {len(train_dataset)} examples\")\n",
    "    \n",
    "    return train_dataset\n",
    "\n",
    "# Load and process datasets\n",
    "try:\n",
    "    train_dataset = load_and_process_datasets()\n",
    "    print(f\"\\n✅ Dataset preparation complete! Dataset shape: {train_dataset.shape}\")\n",
    "    print(f\"Dataset features: {train_dataset.features}\")\n",
    "    print(\"\\nSample from dataset:\")\n",
    "    print(f\"{train_dataset[0]}\")\n",
    "except Exception as e:\n",
    "    print(f\"⚠️ Error in dataset preparation: {e}\")\n",
    "    # Create a minimal dataset for demonstration\n",
    "    from datasets import Dataset\n",
    "    train_dataset = Dataset.from_dict({\n",
    "        \"input_text\": [\"Write a function that\" for _ in range(10)],\n",
    "        \"target_text\": [\"def example():\" for _ in range(10)]\n",
    "    })\n",
    "    print(\"Created emergency backup dataset for demonstration\")"
   ]
  },
