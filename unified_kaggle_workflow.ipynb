    "    else:\n",
    "        # Basic model saving without compatibility wrapping\n",
    "        print(\"Performing basic model export...\")\n",
    "        \n",
    "        # Save model state dict\n",
    "        torch.save(model.state_dict(), f\"{deploy_dir}/model.pt\")\n",
    "        print(f\"✅ Saved basic model to {deploy_dir}/model.pt\")\n",
    "        \n",
    "        # Save model configuration if available\n",
    "        if hasattr(model, 'config'):\n",
    "            model.config.save_pretrained(f\"{deploy_dir}/config\")\n",
    "            print(f\"✅ Saved model configuration to {deploy_dir}/config\")\n",
    "        \n",
    "        # Save tokenizer if available\n",
    "        try:\n",
