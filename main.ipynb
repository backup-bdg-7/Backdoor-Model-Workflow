   "source": [
    "## Step 4 - Prepare Data for AutoTrain\n",
    "\n",
    "We'll now prepare our datasets for AutoTrain fine-tuning using the repository's utilities."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Initialize AutoTrain preprocessor\n",
    "autotrain_preprocessor = AutoTrainPreprocessor(config)\n",
    "\n",
    "# Prepare datasets for each training stage\n",
    "autotrain_datasets = {}\n",
    "\n",
    "for stage_name, dataset in datasets.items():\n",
    "    print(f\"Preparing {stage_name} dataset for AutoTrain...\")\n",
    "    output_file = f\"{stage_name}_train.csv\"\n",
    "    \n",
    "    # Get the dataset format\n",
    "    if 'instruction' in stage_name or 'tuning' in stage_name:\n",
    "        format_type = 'instruction'\n",
    "    elif 'dialogue' in stage_name or 'chat' in stage_name:\n",
    "        format_type = 'chat'\n",
    "    else:\n",
    "        format_type = 'completion'\n",
    "    \n",
    "    # Prepare the dataset\n",
    "    output_path = autotrain_preprocessor.prepare_dataset(\n",
    "        dataset,\n",
    "        format_type=format_type,\n",
    "        output_file=output_file\n",
    "    )\n",
    "    \n",
    "    autotrain_datasets[stage_name] = output_path\n",
    "    print(f\"Saved {stage_name} dataset to {output_path}\")\n",
    "\n",
    "# For the full training workflow, we'll use the instruction_tuning dataset\n",
    "primary_dataset_path = autotrain_datasets.get('instruction_tuning', list(autotrain_datasets.values())[0])\n",
    "print(f\"\\nPrimary dataset for training: {primary_dataset_path}\")"
   ]
