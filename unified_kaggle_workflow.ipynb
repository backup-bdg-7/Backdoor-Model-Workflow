    "   response = requests.post('http://localhost:5000/generate', \n",
    "                           json={{'prompt': 'Write a function to', 'max_length': 50}})\n",
    "   print(response.json()['generated_text'])\n",
    "   ```\n",
    "\n",
    "## Model Files\n",
    "- Full model: `{output_dir}/checkpoints/final_model/`\n",
    "- Model state dict: `{deploy_dir}/model.pt`\n",
    "- Tokenizer: `{deploy_dir}/tokenizer/`\n",
    "\"\"\"\n",
    "        \n",
    "        with open(f\"{deploy_dir}/README.md\", \"w\") as f:\n",
    "            f.write(readme)\n",
    "        \n",
    "        print(f\"✅ Created deployment instructions at {deploy_dir}/README.md\")\n",
    "        \n",
    "except Exception as e:\n",
    "    print(f\"⚠️ Error in model deployment preparation: {e}\")\n",
    "    print(\"Skipping deployment preparation due to errors\")"
   ]
