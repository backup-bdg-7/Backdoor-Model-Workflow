    "            # Save Flask application template\n",
    "            flask_dir = f\"{deploy_dir}/flask\"\n",
    "            os.makedirs(flask_dir, exist_ok=True)\n",
    "            with open(f\"{flask_dir}/app.py\", \"w\") as f:\n",
    "                f.write(flask_basic_template)\n",
    "            print(f\"✅ Created basic Flask application template at {flask_dir}/app.py\")\n",
    "        \n",
    "        # Try to perform CoreML export\n",
    "        try:\n",
    "            from src.deployment.coreml_export import CoreMLModelExporter\n",
    "            coreml_dir = f\"{deploy_dir}/coreml\"\n",
    "            os.makedirs(coreml_dir, exist_ok=True)\n",
    "            \n",
    "            # Check if coremltools is available\n",
    "            try:\n",
    "                import coremltools\n",
    "                coreml_available = True\n",
    "            except ImportError:\n",
    "                coreml_available = False\n",
    "                print(\"ℹ️ coremltools not available - skipping actual conversion but preparing files\")\n",
    "            \n",
    "            if coreml_available:\n",
    "                coreml_exporter = CoreMLModelExporter()\n",
    "                coreml_export_path = coreml_exporter.export_model(\n",
    "                    model=wrapped_model,\n",
    "                    tokenizer=tokenizer,\n",
    "                    output_dir=coreml_dir,\n",
    "                    model_name=f\"model-{timestamp}\",\n",
    "                    include_sample_code=True\n",
    "                )\n",
    "                \n",
    "                print(f\"✅ Exported model for CoreML deployment to {coreml_export_path}\")\n",
    "            else:\n",
    "                # Save a placeholder file explaining CoreML requirements\n",
    "                with open(f\"{coreml_dir}/COREML_INSTRUCTIONS.txt\", \"w\") as f:\n",
    "                    f.write(\"CoreML Conversion Instructions\\n\")\n",
    "                    f.write(\"----------------------------\\n\\n\")\n",
    "                    f.write(\"To convert this model to CoreML format, you need:\\n\")\n",
    "                    f.write(\"1. macOS environment\\n\")\n",
    "                    f.write(\"2. Install coremltools: pip install coremltools\\n\")\n",
    "                    f.write(\"3. Run the conversion using src/deployment/coreml_export.py\\n\\n\")\n",
    "                    f.write(f\"Model file: {deploy_dir}/compatibility_model.pt\\n\")\n",
    "                \n",
    "                print(f\"ℹ️ Created CoreML instructions at {coreml_dir}/COREML_INSTRUCTIONS.txt\")\n",
    "        except Exception as e:\n",
