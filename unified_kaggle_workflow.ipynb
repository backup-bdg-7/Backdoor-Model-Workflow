   "source": [
    "## 3. Model Creation\n",
    "\n",
    "Create the model architecture based on the configuration."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "print(\"\\n==== MODEL CREATION ====\\n\")\n",
    "\n",
    "import torch\n",
    "\n",
    "# Set random seed for reproducibility\n",
    "torch.manual_seed(config.get('seed', 42))\n",
    "np.random.seed(config.get('seed', 42))\n",
    "\n",
    "# Check if GPU is available\n",
    "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "print(f\"Using device: {device}\")\n",
    "\n",
    "try:\n",
    "    # Try to import from project\n",
    "    from src.model.architecture import create_model_from_config, TransformerModel\n",
    "    print(\"✅ Successfully imported project model modules\")\n",
    "    model_source = \"project\"\n",
    "except ImportError:\n",
    "    # Fall back to HuggingFace\n",
    "    print(\"ℹ️ Could not import from project model modules, falling back to HuggingFace\")\n",
    "    from transformers import AutoModelForCausalLM\n",
    "    model_source = \"huggingface\"\n",
    "\n",
    "print(f\"Using {model_source} as the model source\")\n",
    "\n",
    "# Create or load model\n",
    "try:\n",
    "    if model_source == \"project\":\n",
    "        # Create model from configuration\n",
    "        print(\"Creating model from configuration...\")\n",
    "        # Ensure tokenizer vocabulary size is set\n",
    "        if 'tokenizer' not in config or 'vocab_size' not in config['tokenizer']:\n",
    "            config['tokenizer'] = {'vocab_size': 50257}\n",
    "        \n",
    "        # Initialize model\n",
    "        model = create_model_from_config(config)\n",
    "    else:\n",
    "        # Load pretrained model from HuggingFace\n",
    "        try:\n",
    "            model = AutoModelForCausalLM.from_pretrained(\"gpt2\")\n",
    "            print(\"Loaded GPT-2 model from HuggingFace\")\n",
    "        except Exception as e:\n",
    "            print(f\"Error loading GPT-2 model: {e}\")\n",
    "            # Try a smaller model\n",
    "            model = AutoModelForCausalLM.from_pretrained(\"distilgpt2\")\n",
    "            print(\"Loaded DistilGPT-2 model as fallback\")\n",
    "\n",
    "    # Move model to device\n",
    "    model.to(device)\n",
    "\n",
    "    # Print model summary\n",
    "    total_params = sum(p.numel() for p in model.parameters())\n",
    "    trainable_params = sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
    "\n",
    "    print(f\"\\n✅ Model created successfully\")\n",
    "    print(f\"Total parameters: {total_params:,}\")\n",
    "    print(f\"Trainable parameters: {trainable_params:,}\")\n",
    "    print(f\"Model size: {config['model']['size'] if 'model' in config and 'size' in config['model'] else 'unknown'}\")\n",
    "    \n",
    "except Exception as e:\n",
    "    print(f\"⚠️ Error creating model: {e}\")\n",
    "    # Create a minimal model for demonstration\n",
    "    from transformers import AutoModelForCausalLM\n",
    "    model = AutoModelForCausalLM.from_pretrained(\"sshleifer/tiny-gpt2\")\n",
    "    model.to(device)\n",
    "    print(\"Created tiny GPT-2 model for demonstration\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## 4. Tokenizer Setup\n",
    "\n",
    "Initialize the tokenizer for the model."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "source": [
    "print(\"\\n==== TOKENIZER SETUP ====\\n\")\n",
    "\n",
    "# Initialize tokenizer\n",
    "from transformers import AutoTokenizer\n",
    "\n",
    "try:\n",
    "    # Try custom tokenizer import first\n",
    "    try:\n",
    "        from src.utils.tokenization import Tokenizer\n",
    "        tokenizer_source = \"project\"\n",
    "        print(\"Found project tokenizer module\")\n",
    "    except ImportError:\n",
    "        tokenizer_source = \"huggingface\"\n",
    "        print(\"Using HuggingFace tokenizers\")\n",
    "    \n",
    "    # Load tokenizer based on source\n",
    "    if tokenizer_source == \"project\" and hasattr(Tokenizer, 'from_config'):\n",
    "        tokenizer = Tokenizer.from_config(config)\n",
    "        print(\"Created tokenizer from project configuration\")\n",
    "    else:\n",
    "        # Default to GPT-2 tokenizer\n",
    "        tokenizer = AutoTokenizer.from_pretrained(\"gpt2\")\n",
    "        if tokenizer.pad_token is None:\n",
    "            tokenizer.pad_token = tokenizer.eos_token\n",
    "        print(\"Using GPT-2 tokenizer\")\n",
    "    \n",
    "    print(f\"✅ Tokenizer initialized with vocabulary size: {len(tokenizer)}\")\n",
    "    print(f\"Special tokens: {tokenizer.special_tokens_map}\")\n",
    "    \n",
    "except Exception as e:\n",
    "    print(f\"⚠️ Error initializing tokenizer: {e}\")\n",
    "    \n",
    "    # Create a simple fallback tokenizer\n",
    "    class SimpleTokenizer:\n",
    "        def __init__(self):\n",
    "            self.vocab = {}\n",
    "            self.pad_token = \"<pad>\"\n",
    "            self.eos_token = \"</s>\"\n",
    "            self.pad_token_id = 0\n",
    "            self.eos_token_id = 1\n",
    "            self.special_tokens_map = {\"pad_token\": \"<pad>\", \"eos_token\": \"</s>\"}\n",
    "                \n",
    "        def encode(self, text, return_tensors=None, padding=None, truncation=None):\n",
    "            if isinstance(text, list):\n",
    "                return [self.encode(t, return_tensors, padding, truncation) for t in text]\n",
    "                \n",
    "            tokens = text.split()\n",
    "            ids = []\n",
    "            for token in tokens:\n",
    "                if token not in self.vocab:\n",
    "                    self.vocab[token] = len(self.vocab) + 10  # Start after special tokens\n",
    "                ids.append(self.vocab[token])\n",
    "            \n",
    "            if return_tensors == \"pt\":\n",
    "                return {\"input_ids\": torch.tensor([ids])}\n",
    "            return {\"input_ids\": ids}\n",
    "            \n",
    "        def decode(self, ids, skip_special_tokens=True):\n",
    "            # Basic decoding that just joins ids with spaces\n",
    "            if isinstance(ids, torch.Tensor):\n",
    "                ids = ids.tolist()\n",
    "            return \" \".join([str(id) for id in ids])\n",
    "        \n",
    "        def __call__(self, text, return_tensors=None, padding=None, truncation=None):\n",
    "            return self.encode(text, return_tensors, padding, truncation)\n",
    "            \n",
    "        def __len__(self):\n",
    "            return len(self.vocab) + 10  # Add special tokens\n",
    "    \n",
    "    tokenizer = SimpleTokenizer()\n",
    "    print(\"Created simple fallback tokenizer\")"
   ]
