    "                    \"n_layers\": 12,\n",
    "                    \"n_heads\": 12,\n",
    "                    \"d_model\": 768,\n",
    "                    \"d_ff\": 3072,\n",
    "                    \"max_seq_length\": 2048\n",
    "                },\n",
    "                \"medium\": {\n",
    "                    \"n_layers\": 24,\n",
    "                    \"n_heads\": 16,\n",
    "                    \"d_model\": 1024,\n",
    "                    \"d_ff\": 4096,\n",
    "                    \"max_seq_length\": 4096\n",
    "                },\n",
    "                \"large\": {\n",
    "                    \"n_layers\": 32,\n",
    "                    \"n_heads\": 32,\n",
    "                    \"d_model\": 2048,\n",
    "                    \"d_ff\": 8192,\n",
    "                    \"max_seq_length\": 8192\n",
    "                }\n",
    "            },\n",
    "            \"activation\": \"gelu\",\n",
    "            \"dropout\": 0.1,\n",
    "            \"attention\": {\n",
    "                \"type\": \"flash_attention\",\n",
    "                \"causal\": True,\n",
    "                \"rotary_embedding\": True\n",
    "            }\n",
    "        },\n",
    "        \"tokenizer\": {\n",
    "            \"vocab_size\": 50257\n",
    "        },\n",
    "        \"datasets\": {\n",
    "            \"core_datasets\": [\n",
    "                {\n",
    "                    \"name\": \"openai/humaneval\",\n",
    "                    \"type\": \"huggingface\",\n",
    "                    \"task\": \"code_generation\",\n",
    "                    \"weight\": 1.0\n",
    "                }\n",
    "            ],\n",
    "            \"additional_datasets\": []\n",
    "        },\n",
    "        \"training\": {\n",
    "            \"stages\": [\n",
    "                {\n",
    "                    \"name\": \"pretraining\",\n",
    "                    \"datasets\": [\"openai/humaneval\"],\n",
    "                    \"epochs\": 3,\n",
    "                    \"learning_rate\": {\n",
    "                        \"initial\": 5e-5,\n",
    "                        \"min\": 5e-6,\n",
    "                        \"schedule\": \"cosine\",\n",
    "                        \"warmup_steps\": 100\n",
    "                    }\n",
    "                }\n",
    "            ],\n",
    "            \"optimizer\": {\n",
    "                \"name\": \"adamw\",\n",
    "                \"weight_decay\": 0.01,\n",
    "                \"beta1\": 0.9,\n",
    "                \"beta2\": 0.999,\n",
    "                \"eps\": 1e-8\n",
    "            },\n",
    "            \"mixed_precision\": \"fp16\",\n",
    "            \"gradient_checkpointing\": True,\n",
    "            \"gradient_clipping\": 1.0\n",
    "        }\n",
    "    }\n",
    "\n",
    "# Update output directory in config\n",
    "config['output_dir'] = output_dir\n",
    "\n",
    "# Save updated config\n",
    "config_output_path = f\"{output_dir}/config.yaml\"\n",
    "os.makedirs(os.path.dirname(config_output_path), exist_ok=True)\n",
    "with open(config_output_path, 'w') as f:\n",
    "    yaml.dump(config, f)\n",
    "\n",
    "print(f\"Configuration saved to {config_output_path}\")\n",
    "\n",
    "# Display configuration summary\n",
    "print(f\"\\nProject name: {config['project_name']}\")\n",
    "print(f\"Model architecture: {config['model'].get('architecture', 'transformer')}\")\n",
    "print(f\"Model size: {config['model']['size']}\")\n",
    "num_datasets = len(config['datasets']['core_datasets']) + len(config['datasets'].get('additional_datasets', []))\n",
    "print(f\"Number of configured datasets: {num_datasets}\")\n",
    "if 'training' in config and 'stages' in config['training']:\n",
    "    print(f\"Number of training stages: {len(config['training']['stages'])}\")"
   ]
